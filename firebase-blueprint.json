{
  "entities": {
    "SiteContent": {
      "title": "SiteContent",
      "description": "The main configuration for the entire website content, including brand identity, services, and portfolio.",
      "type": "object",
      "properties": {
        "brand": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "tagline": { "type": "string" },
            "taglineExtended": { "type": "string" },
            "location": { "type": "string" },
            "contact": {
              "type": "object",
              "properties": {
                "phone": { "type": "string" },
                "email": { "type": "string" }
              },
              "required": ["phone", "email"]
            }
          },
          "required": ["name", "tagline", "taglineExtended", "location", "contact"]
        },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "short": { "type": "string" },
              "description": { "type": "string" },
              "whoItsFor": { "type": "string" },
              "outcome": { "type": "string" },
              "icon": { "type": "string" },
              "visualUrl": { "type": "string" },
              "visualType": { "type": "string", "enum": ["image", "video"] },
              "photoCategory": { "type": "string" }
            }
          }
        },
        "portfolio": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "category": { "type": "string" },
              "title": { "type": "string" },
              "placeholder": { "type": "string" },
              "url": { "type": "string" },
              "videoUrl": { "type": "string" },
              "type": { "type": "string", "enum": ["video", "photo"] },
              "alt": { "type": "string" },
              "client": { "type": "string" },
              "year": { "type": "string" },
              "isFeatured": { "type": "boolean" },
              "images": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "about": {
          "type": "object",
          "properties": {
            "heroTitle": { "type": "string" },
            "heroSubtitle": { "type": "string" },
            "storyTitle": { "type": "string" },
            "storyText1": { "type": "string" },
            "storyText2": { "type": "string" },
            "storyText3": { "type": "string" },
            "quote": { "type": "string" },
            "profileImage": { "type": "string" }
          }
        },
        "home": {
          "type": "object",
          "properties": {
            "lensTitle": { "type": "string" },
            "lensText": { "type": "string" },
            "lensImage": { "type": "string" },
            "ctaBackground": { "type": "string" },
            "heroVisuals": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": { "type": "string" },
                  "type": { "type": "string", "enum": ["image", "video"] },
                  "category": { "type": "string" }
                }
              }
            }
          }
        },
        "promo": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "title": { "type": "string" },
            "message": { "type": "string" },
            "code": { "type": "string" }
          }
        },
        "testimonials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "author": { "type": "string" },
              "role": { "type": "string" },
              "content": { "type": "string" },
              "rating": { "type": "number" },
              "date": { "type": "string" },
              "avatar": { "type": "string" }
            }
          }
        }
      },
      "required": ["brand", "services", "portfolio", "about", "home", "promo", "testimonials"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Information from a potential client inquiry.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "service": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "contacted", "converted", "archived"] },
        "bookingDate": { "type": "string" },
        "bookingStatus": { "type": "string", "enum": ["none", "requested", "confirmed"] }
      },
      "required": ["name", "email", "service", "message", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A confirmed project being managed by the agency.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["planning", "production", "post-production", "review", "completed", "halted"] },
        "progress": { "type": "number" },
        "leadId": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string" },
        "bookingDate": { "type": "string" }
      },
      "required": ["title", "clientName", "clientEmail", "status", "progress", "createdAt", "updatedAt"]
    },
    "Communication": {
      "title": "Communication",
      "description": "A message exchanged between the agency and a lead/client.",
      "type": "object",
      "properties": {
        "relatedId": { "type": "string" },
        "relatedType": { "type": "string", "enum": ["lead", "project"] },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      },
      "required": ["relatedId", "relatedType", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/settings/content": {
      "schema": "SiteContent",
      "description": "Singleton document containing all site-wide content settings."
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Individual client inquiries."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Active and completed projects."
    },
    "/communications/{msgId}": {
      "schema": "Communication",
      "description": "History of messages for leads and projects."
    }
  }
}
