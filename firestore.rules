rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isAdmin() {
      // Hardcoded admin email based on project requirement
      return isEmailVerified() && request.auth.token.email == 'jonniarmani@gmail.com';
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // -------------------------------------------------------------------------
    // VALIDATION HELPERS
    // -------------------------------------------------------------------------
    
    function isValidSiteContent(data) {
      return data.keys().hasAll(['brand', 'services', 'portfolio', 'about', 'home', 'promo'])
        && data.brand is path || data.brand is map
        && data.brand.name is string && data.brand.name.size() < 200
        && data.brand.contact is map
        && data.services is list
        && data.portfolio is list
        && data.about is map
        && data.home is map
        && data.promo is map;
    }

    // -------------------------------------------------------------------------
    // ACCESS RULES
    // -------------------------------------------------------------------------

    // Default deny for all collections
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Website Settings
    match /settings/{settingId} {
      allow read: if true; // Public read for site content
      
      allow create, update: if (
        isAdmin() && 
        isValidId(settingId) &&
        (settingId == 'content' ? isValidSiteContent(incoming()) : true)
      );
      
      allow delete: if isAdmin();
    }

    // Inquiries / Leads
    match /leads/{leadId} {
      allow create: if (
        isValidId(leadId) &&
        incoming().keys().hasAll(['name', 'email', 'service', 'message', 'createdAt']) &&
        incoming().name is string && incoming().name.size() > 0 &&
        incoming().email is string && incoming().email.matches('^.+@.+\\..+$') &&
        incoming().createdAt == request.time
      );
      
      allow read, update, delete: if isAdmin();
    }
  }
}
