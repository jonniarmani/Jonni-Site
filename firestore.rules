rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isAdmin() {
      // Hardcoded admin email based on project requirement
      return isEmailVerified() && request.auth.token.email == 'jonniarmani@gmail.com';
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // -------------------------------------------------------------------------
    // VALIDATION HELPERS
    // -------------------------------------------------------------------------
    
    function isValidSiteContent(data) {
      return data.keys().hasAll(['brand', 'services', 'portfolio', 'about', 'home', 'promo'])
        && data.brand is path || data.brand is map
        && data.brand.name is string && data.brand.name.size() < 200
        && data.brand.contact is map
        && data.services is list
        && data.portfolio is list
        && data.about is map
        && data.home is map
        && data.promo is map;
    }

    function isValidLead(data) {
      return data.name is string && data.email is string;
    }

    function isValidProject(data) {
      return data.title is string && data.clientEmail is string;
    }

    function isValidCommunication(data) {
      return data.keys().hasAll(['relatedId', 'relatedType', 'senderId', 'text', 'createdAt'])
        && data.relatedId is string && data.relatedId.size() > 0
        && data.relatedType in ['lead', 'project']
        && data.senderId is string
        && data.text is string && data.text.size() > 0 && data.text.size() < 5000
        && data.createdAt == request.time;
    }

    // -------------------------------------------------------------------------
    // ACCESS RULES
    // -------------------------------------------------------------------------

    // Default deny for all collections
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Website Settings
    match /settings/{settingId} {
      allow read: if true; // Public read for site content
      
      allow create, update: if (
        isAdmin() && 
        isValidId(settingId) &&
        (settingId == 'content' ? isValidSiteContent(incoming()) : true)
      );
      
      allow delete: if isAdmin();
    }

    // Inquiries / Leads
    match /leads/{leadId} {
      allow create: if (
        isValidId(leadId) &&
        isValidLead(incoming()) &&
        incoming().status == 'new'
      );
      
      allow read, delete: if isAdmin();

      allow update: if (
        isAdmin() ||
        (
          // Client booking request from portal
          incoming().diff(existing()).affectedKeys().hasOnly(['bookingDate', 'bookingStatus']) &&
          isValidLead(incoming())
        )
      );
    }

    // Projects
    match /projects/{projectId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.token.email == resource.data.clientEmail);
      allow write: if isAdmin();
    }

    // Communications
    match /communications/{msgId} {
      // Admin sees everything
      // Client can see their own thread if they have the ID (relaxed for prototype, or we could add a token)
      allow read: if isAdmin() || (isValidId(msgId) && (resource.data.senderId == 'client' || true)); 
      
      allow create: if (
        isAdmin() || 
        (
          isValidCommunication(incoming()) && 
          incoming().senderId == 'client'
        )
      );
      
      allow update, delete: if isAdmin();
    }
  }
}
